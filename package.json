{
  "name": "@driverforge/gayle",
  "version": "5.6.0",
  "description": "Package to deploy parameters to AWS and Azure",
  "repository": {
    "type": "git",
    "url": "https://github.com/driverforge/gayle.git"
  },
  "author": "Driverforge",
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "bin": "./bin/gayle",
  "files": [
    "bin/",
    "lib/",
    "!lib/**/*.test.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "yarn eslint .",
    "test": "yarn jest --coverage",
    "prepare": "husky install"
  },
  "keywords": [
    "amazon-web-services",
    "aws-parameter-store",
    "azure-key-vault",
    "configuration-management",
    "aws",
    "azure"
  ],
  "bugs": {
    "url": "https://github.com/driverforge/gayle/issues"
  },
  "homepage": "https://github.com/driverforge/gayle",
  "dependencies": {
    "@aws-sdk/client-cloudformation": "^3.1007.0",
    "@aws-sdk/client-ssm": "^3.1007.0",
    "@aws-sdk/client-sts": "^3.1006.0",
    "@azure/identity": "^4.2.0",
    "@azure/keyvault-secrets": "^4.8.0",
    "chalk": "^4.1.0",
    "commander": "^7.1.0",
    "dataloader": "^2.0.0",
    "deep-map": "^2.0.0",
    "es6-weak-map": "^2.0.3",
    "js-yaml": "^4.0.0",
    "lodash": "^4.17.21",
    "prompt": "^1.1.0",
    "root-path": "^0.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^12.0.1",
    "@commitlint/config-conventional": "^12.0.1",
    "eslint": "^7.21.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^24.2.1",
    "eslint-plugin-prettier": "^3.3.1",
    "husky": "^6.0.0",
    "jest": "^26.6.3",
    "pinst": "^2.1.6",
    "prettier": "^1.18.2"
  }
}
